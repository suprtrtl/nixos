shell-integration = zsh
theme = One Half Dark

font-size = 10

#custom-shader = ~/.config/ghostty/shaders/crt.glsl

mouse-hide-while-typing = true
scrollback-limit = 1000000

keybind = ctrl+n=new_window

keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

keybind = ctrl+s>h=new_split:left
keybind = ctrl+s>j=new_split:down
keybind = ctrl+s>k=new_split:up
keybind = ctrl+s>l=new_split:right
keybind = ctrl+s>f=toggle_split_zoom

keybind = ctrl+alt+h=resize_split:left,10
keybind = ctrl+alt+j=resize_split:down,10
keybind = ctrl+alt+k=resize_split:up,10
keybind = ctrl+alt+l=resize_split:right,10

keybind = ctrl+s>bracketRight=next_tab
keybind = ctrl+s>bracketLeft=previous_tab
keybind = ctrl+s>t=new_tab
keybind = ctrl+s>w=close_tab:this

keybind = ctrl+s>shift+semicolon=toggle_command_palette
keybind = ctrl+s>backquote=toggle_quick_terminal

window-save-state = always
